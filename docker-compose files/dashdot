services:

  dashdot:
    image: mauricenino/dashdot:latest
    container_name: dashdot
    restart: unless-stopped
    privileged: true
    ports:
      - 3001:3001
    environment:
      - DASHDOT_ALWAYS_SHOW_PERCENTAGES=true
      - DASHDOT_ACCEPT_OOKLA_EULA=true
      - DASHDOT_DISABLE_TILT=true
      - DASHDOT_DISABLE_HOST=true
      - DASHDOT_OVERRIDE_OS=DSM
    volumes:
      - /volume1/docker/dashdot/data/network:/mnt/host_ns_net:ro
      - /volume1/docker/dashdot/data/media:/mnt/host_media:ro
      - /volume1/docker/dashdot/data/host:/mnt/host_mnt:ro
    labels:
      - org.hotio.pullio.update=true
      - org.hotio.pullio.notify=true
      - org.hotio.pullio.discord.webhook=*****
